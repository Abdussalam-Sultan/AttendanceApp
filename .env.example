# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Backend Configuration
DATABASE_URL=mysql://user:password@localhost:3306/doorlog
# Or use individual variables (Safer for special characters)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=attendanceappdb
DB_SSL=false

JWT_SECRET=your_jwt_secret_here
# Default Admin Credentials
DEFAULT_ADMIN_EMAIL=admin@doorlog.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Admin User

# Authentication
JWT_SECRET=your_jwt_secret_here

# Database (MySQL - optional, fallback to SQLite if not provided)
DB_HOST=
DB_USER=
DB_NAME=
DB_PASSWORD=
DB_PORT=3306

# Cloudinary (Required for profile image persistence)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

